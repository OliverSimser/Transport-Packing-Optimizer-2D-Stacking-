                Loop
    
                With wsSkidding
                    .Range(.Cells(topRow, startCol), .Cells(rowPointer - 1, startCol + 1)).Borders(xlEdgeTop).Weight = bold
                    .Range(.Cells(topRow, startCol), .Cells(rowPointer - 1, startCol + 1)).Borders(xlEdgeBottom).Weight = bold
                    .Range(.Cells(topRow, startCol), .Cells(rowPointer - 1, startCol + 1)).Borders(xlEdgeLeft).Weight = bold
                    .Range(.Cells(topRow, startCol), .Cells(rowPointer - 1, startCol + 1)).Borders(xlEdgeRight).Weight = bold
                End With
    
                wsSkidding.Columns(startCol).ColumnWidth = 5.78
                wsSkidding.Columns(startCol + 1).ColumnWidth = 34.78
                wsSkidding.Columns(startCol + 2).ColumnWidth = 9.78
                wsSkidding.Range(wsSkidding.Cells(topRow, startCol), wsSkidding.Cells(rowPointer - 1, startCol + 1)).RowHeight = 20
                currentSkid = currentSkid + 1
                startCol = startCol + 4
            Loop
        
        Next hKey
    Next sectionNum
        
    
    Dim numSkids As Long, searchCol As Long
    Dim skidColStart As Long, skidColEnd As Long
    Dim maxRow As Long, curSkidRow As Long
    Dim valuesDict As Object, val As Variant
    Dim tempRange As Range
    Dim rowLookup As Object
    
    numSkids = currentSkid - 1
    
    Application.DisplayAlerts = False
    On Error Resume Next
    Worksheets("SKIDs").Delete
    On Error GoTo 0
    Application.DisplayAlerts = True
    
    Set wsSkids = Worksheets.Add(After:=wsCovers)
    wsSkids.Name = "SKIDs"
        
    startCol = 1
    searchCol = 1
    

    For currentSkid = 1 To numSkids
        rowPointer = 1
        layerCount = 1

        With wsSkids.Range(wsSkids.Cells(rowPointer, startCol), wsSkids.Cells(rowPointer, startCol + 1))
            .Merge
            .Value = wsSkidding.Cells(1, searchCol).Value
            .Font.bold = True
            .HorizontalAlignment = xlCenter
            .VerticalAlignment = xlCenter
            .Borders(xlEdgeTop).Weight = xlMedium
            .Borders(xlEdgeBottom).Weight = xlMedium
            .Borders(xlEdgeLeft).Weight = xlMedium
            .Borders(xlEdgeRight).Weight = xlMedium
        End With
        rowPointer = rowPointer + 1

        Do While Application.WorksheetFunction.CountA(wsSkidding.Columns(searchCol)) > 1

            Dim maxVal As Double
            Dim lastDataRow As Long
            Dim curRow As Long
            
            wsSkids.Cells(rowPointer, startCol).Value = "L" & layerCount
            
            ' Find last row with data in the current SKID's 2nd column (assuming col with no blanks)
            lastDataRow = wsSkidding.Cells(wsSkidding.Rows.Count, searchCol + 1).End(xlUp).Row
            
            maxVal = -1 ' initialize to very small number
            maxRow = 0
            
            For curRow = 2 To lastDataRow ' assuming row 1 is headers
                If IsNumeric(wsSkidding.Cells(curRow, searchCol + 2).Value) Then
                    If wsSkidding.Cells(curRow, searchCol + 2).Value > maxVal Then
                        maxVal = wsSkidding.Cells(curRow, searchCol + 2).Value
                        maxRow = curRow
                    End If
                End If
            Next curRow
            
            If maxRow = 0 Then
                MsgBox "No numeric data found in SKID " & currentSkid
                Exit For
            End If
            Dim layerEndRow As Long
            layerEndRow = maxRow
            
            ' Loop downwards until length column has a value or end of data
            For curRow = maxRow + 1 To lastDataRow
                If IsEmpty(wsSkidding.Cells(curRow, searchCol + 2).Value) Then
                    layerEndRow = curRow ' include empty length row
                Else
                    Exit For ' stop at next filled length value
                End If
            Next curRow
            
            Dim copyRow As Long
            For copyRow = maxRow To layerEndRow
                wsSkids.Cells(rowPointer, startCol + 1).Value = wsSkidding.Cells(copyRow, searchCol + 1).Value
                rowPointer = rowPointer + 1
            Next copyRow
            layerCount = layerCount + 1
            
            ' Delete the copied rows from wsSkidding and shift up
            wsSkidding.Range(wsSkidding.Cells(maxRow, searchCol), _
                             wsSkidding.Cells(layerEndRow, searchCol + 2)).Delete Shift:=xlUp
        Loop
        
        With wsSkids
            Dim formatRange As Range
            Set formatRange = .Range(.Cells(2, startCol), .Cells(rowPointer - 1, startCol + 1))
            
            ' Apply bold borders to all cells in the range
            With formatRange.Borders
                .LineStyle = xlContinuous
                .Weight = xlMedium
            End With
        
            ' Set individual sides (optional, for full control)
            With formatRange
                .Borders(xlEdgeTop).Weight = xlMedium
                .Borders(xlEdgeBottom).Weight = xlMedium
                .Borders(xlEdgeLeft).Weight = xlMedium
                .Borders(xlEdgeRight).Weight = xlMedium
                .Borders(xlInsideHorizontal).Weight = xlThin
                .Borders(xlInsideVertical).Weight = xlThin
            End With
            
            ' Set column widths
            .Columns(startCol).ColumnWidth = 5.78
            .Columns(startCol + 1).ColumnWidth = 34.78
            .Columns(startCol + 2).ColumnWidth = 9.78
            
            ' Set row height
            formatRange.RowHeight = 20
        End With
        
        searchCol = searchCol + 4
        startCol = startCol + 4
    Next currentSkid

    Application.DisplayAlerts = False
    ThisWorkbook.Sheets("SKIDDING").Delete
    Application.DisplayAlerts = True

 End Sub

